---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeedCard from "../../components/FeedCard.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("work-log", entry => !entry.data.draft))
  .sort((a, b) => b.data.monthStart.getTime() - a.data.monthStart.getTime());

// Pull the first section-figure SVG out of each entry's own markdown so
// every card carries that month's icon rather than a shared one.
const firstSvg = (body?: string) => body?.match(/<svg[\s\S]*?<\/svg>/i)?.[0];
---
<BaseLayout
  title="Work Log"
  description="Monthly notes on what I am building, breaking, and learning."
>
  <header class="page-header">
    <div class="container">
      <p class="section-eyebrow">Work Log</p>
      <h1>Monthly notes from the field</h1>
      <p class="lead">What I am building, breaking, and learning. Newest at the top.</p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      {entries.length === 0 ? (
        <p style="text-align:center; color:var(--page-fg-soft);">No entries published yet.</p>
      ) : (
        <ul class="feed-list">
          {entries.map(entry => (
            <li>
              <FeedCard
                href={`/work-log/${entry.id}`}
                meta={entry.data.monthStart.toLocaleDateString("en-CA", {
                  year: "numeric",
                  month: "long",
                  timeZone: "UTC",
                })}
                title={entry.data.title}
                headline={entry.data.summary}
                svg={firstSvg(entry.body)}
              />
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
