---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Capabilities from "../components/Capabilities.astro";
import Certifications from "../components/Certifications.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { getCollection } from "astro:content";

const latestMonth = (await getCollection("work-log", (entry) => !entry.data.draft))
  .sort((a, b) => b.data.monthStart.getTime() - a.data.monthStart.getTime())[0];

const latestArticle = (await getCollection("writing", (entry) => !entry.data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())[0];

const fmtMonth = (d: Date) =>
  d.toLocaleDateString("en-CA", { year: "numeric", month: "long", timeZone: "UTC" });
const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-CA", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });

const firstSvg = (body?: string) => body?.match(/<svg[\s\S]*?<\/svg>/i)?.[0];

// "Latest" section — each collection's newest item, ordered newest-first
// (most recently dated card sits left on desktop / top on mobile).
type LatestCard = {
  kind: "worklog" | "writing";
  date: Date;
  href: string;
  meta: string;
  title: string;
  cta: string;
  image?: string;
  imageAlt?: string;
  svg?: string;
};
const latestCards: LatestCard[] = [];
if (latestMonth) {
  latestCards.push({
    kind: "worklog",
    date: latestMonth.data.monthStart,
    href: "/now",
    meta: `Work Log · ${fmtMonth(latestMonth.data.monthStart)}`,
    title: latestMonth.data.title,
    cta: "Read the month",
    svg: firstSvg(latestMonth.body),
  });
}
if (latestArticle?.data.heroImage) {
  latestCards.push({
    kind: "writing",
    date: latestArticle.data.pubDate,
    href: `/writing/${latestArticle.id}`,
    meta: `Writing · ${fmtDate(latestArticle.data.pubDate)}`,
    title: latestArticle.data.title,
    cta: "Read the article",
    image: latestArticle.data.heroImage.replace(/^https:\/\/lucianomori\.cloud/, ""),
    imageAlt: latestArticle.data.heroImageAlt ?? latestArticle.data.title,
  });
}
latestCards.sort((a, b) => b.date.getTime() - a.date.getTime());
---
<BaseLayout
  title="Luciano Mori · Sr. DevOps · Cloud, AI & Security"
  ogType="profile"
  showJsonLd={true}
>
  <Hero />
  <Capabilities />
  <Certifications />

  {latestCards.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="section-eyebrow">Latest</p>
            <h2 class="section-title">Fresh from the desk.</h2>
          </div>
          <p class="section-lead">A monthly recap and the occasional long-form.</p>
        </div>
        <div class="latest-grid">
          {latestCards.map((card) => (
            <a class="latest-card" href={card.href}>
              {card.kind === "writing" ? (
                <div class="latest-visual latest-photo">
                  <img src={card.image} alt={card.imageAlt} width="600" height="360" loading="lazy" decoding="async" />
                </div>
              ) : (
                <div class="latest-visual latest-icon" set:html={card.svg ?? `<svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><line x1="40" y1="8" x2="40" y2="16" /><circle cx="40" cy="6" r="2" fill="currentColor" stroke="none" /><rect x="14" y="16" width="52" height="40" rx="8" /><circle cx="28" cy="32" r="3" fill="currentColor" stroke="none" /><circle cx="52" cy="32" r="3" fill="currentColor" stroke="none" /><rect x="26" y="44" width="28" height="4" rx="1" fill="currentColor" stroke="none" /><line x1="6" y1="34" x2="14" y2="34" /><line x1="66" y1="34" x2="74" y2="34" /><rect x="22" y="60" width="36" height="14" rx="2" /><line x1="40" y1="56" x2="40" y2="60" /></svg>`}></div>
              )}
              <div class="latest-body">
                <p class="latest-meta">{card.meta}</p>
                <p class="latest-title">{card.title}</p>
                <span class="latest-cta">
                  {card.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBanner />
</BaseLayout>

<script is:inline>
  (function () {
    // Cert counter speedometer
    var counter = document.getElementById('certCount');
    if (counter) {
      var fallback = parseInt(counter.dataset.target, 10) || 111;
      var rafId = null;
      var easeOut = function (t) { return 1 - Math.pow(1 - t, 3); };
      var animateTo = function (target, duration) {
        if (rafId) cancelAnimationFrame(rafId);
        var from = parseInt(counter.textContent, 10) || 0;
        if (from === target) return;
        var start = performance.now();
        var tick = function (now) {
          var t = Math.min(1, (now - start) / duration);
          counter.textContent = Math.round(from + (target - from) * easeOut(t));
          if (t < 1) rafId = requestAnimationFrame(tick);
        };
        rafId = requestAnimationFrame(tick);
      };
      animateTo(fallback, 1600);
      var ctrl = new AbortController();
      var timeout = setTimeout(function () { ctrl.abort(); }, 3000);
      fetch('https://www.credly.com/users/luciano-s-mori/badges.json', { signal: ctrl.signal })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(); })
        .then(function (d) {
          clearTimeout(timeout);
          var n = d && d.metadata && d.metadata.total_count;
          if (Number.isFinite(n) && n > 0 && n !== fallback) animateTo(n, 700);
        })
        .catch(function () { clearTimeout(timeout); });
    }

    // BlackHat spotlight: hover/focus the hero "2025" → highlight the featured card
    var bhMeta = document.getElementById('bhMeta');
    var bhCard = document.getElementById('featured-blackhat');
    if (bhMeta && bhCard) {
      bhMeta.addEventListener('mouseenter', function () { bhCard.classList.add('is-spotlit'); });
      bhMeta.addEventListener('mouseleave', function () { bhCard.classList.remove('is-spotlit'); });
      bhMeta.addEventListener('focus',     function () { bhCard.classList.add('is-spotlit'); });
      bhMeta.addEventListener('blur',      function () { bhCard.classList.remove('is-spotlit'); });
      bhMeta.addEventListener('click', function (e) {
        e.preventDefault();
        bhCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        bhCard.classList.add('is-spotlit');
        setTimeout(function () { bhCard.classList.remove('is-spotlit'); }, 1600);
      });
    }
  })();
</script>
