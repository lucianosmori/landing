        <a class="hero-meta-item hero-meta-link is-blackhat" id="bhMeta" href="#featured-blackhat" aria-label="2025 @ Black Hat USA — jump to card">
          <span class="hero-meta-num">2025</span>
          <span class="hero-meta-label">@ Black Hat USA</span>
        </a>
      </div>
    </div>
    <div class="hero-right">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">~/luciano · zsh</span>
        </div>
        <div class="terminal-body">
          <div class="term-line"><span class="term-prompt">›</span> <span class="term-cmd">whoami</span></div>
          <div class="term-line">luciano.mori · sr. devops engineer · ottawa 🇨🇦</div>
          <div class="term-line">&nbsp;</div>
          <div class="term-line"><span class="term-prompt">›</span> <span class="term-cmd">cat focus.yaml</span></div>
          <div class="term-line"><span class="term-key">role</span>: <span class="term-val">"Sr. DevOps Engineer"</span></div>
          <div class="term-line"><span class="term-key">stack</span>: <span class="term-val">[aws, azure, gcp]</span></div>
          <div class="term-line"><span class="term-key">specialties</span>:</div>
          <div class="term-line">&nbsp;&nbsp;- <span class="term-val">cost-efficient AI workflows</span></div>
          <div class="term-line">&nbsp;&nbsp;- <span class="term-val">secure CI/CD &amp; IaC</span></div>
          <div class="term-line">&nbsp;&nbsp;- <span class="term-val">agentic systems on cloud</span></div>
          <div class="term-line"><span class="term-key">last_seen</span>: <span class="term-warn">"BlackHat 2025 · Snyk booth"</span></div>
          <div class="term-line">&nbsp;</div>
          <div class="term-line"><span class="term-prompt">›</span> <span class="term-cmd">ssh you@team</span><span class="term-cursor"></span></div>
        </div>
      </div>
    </div>
  </div>
